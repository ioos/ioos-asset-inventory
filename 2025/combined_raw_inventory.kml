            <SimpleData name="Currently_Operational">Y</SimpleData>
            <SimpleData name="Platform_Funder">AOOS, AKDNR</SimpleData>
            <SimpleData name="RA_Funded">Yp</SimpleData>
            <SimpleData name="Platform_Operator">AK DNR</SimpleData>
            <SimpleData name="Operator_Sector">gov_state</SimpleData>
            <SimpleData name="Platform_Maintainer">Alaska Department of Natural Resources</SimpleData>
            <SimpleData name="Data_Manager">Stillwater Technologies, AOOS, Axiom Data Science</SimpleData>
            <SimpleData name="Variable_Names">sea_surface_height_above_sea_level</SimpleData>
            <SimpleData name="Additional_notes"><![CDATA[This Stillwater Technologies iGage began collecting data on July 24, 2020. It was installed on a wood post pier. The datum was previously established at this location in April, 2019 by JOA Surveys, LLC. JOA used their own calculator on data collected between September and November, 2019. On 8/4/2022, the previous iGage sensor was replaced with an iRadar. On 11/21/2022, the previous iRadar sensor was replaced with an iGage. To see all the Tier C water level data stations in the AWLW Portal, https://water-level-watch.portal.aoos.org/#search?type_group=sensor_stations&tag|tag=tier-c&page=1]]></SimpleData>
            <SimpleData name="file">AOOS.xlsx</SimpleData>
