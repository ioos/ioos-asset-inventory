        <ExtendedData>
          <SchemaData schemaUrl="#combined_raw_inventory.schema">
            <SimpleData name="RA">AOOS</SimpleData>
            <SimpleData name="Station_ID">dillingham-2-collocated-sensors</SimpleData>
            <SimpleData name="WMO_CMAN_ID">New 2021</SimpleData>
            <SimpleData name="Station_Long_Name">Dillingham 2 collocated Water Level Sensors (Gauge 1 Bubbler; Gauge 2 Radar)</SimpleData>
