            <SimpleData name="Longitude">-162.006498</SimpleData>
            <SimpleData name="Platform_Type">Fixed</SimpleData>
            <SimpleData name="Station_Deployment">05/26/2018 (Station Install date); 05/31/2018 (Data processed start date by JOA Surveys)</SimpleData>
            <SimpleData name="Currently_Operational">Y</SimpleData>
            <SimpleData name="Platform_Funder">AOOS, UNAVCO</SimpleData>
            <SimpleData name="RA_Funded">Yf (AOOS funded the installation); Yp UNAVCO is payin for data filtration costs</SimpleData>
